  "keyFeatures": [
    "Cross-platform (Web, iOS, Android) via Expo React Native",
    "Real-time feeds with Socket.IO",
    "User mentions with @username autocomplete",
    "Hashtag trending system",
    "ActivityPub / Fediverse federation",
    "AI assistant (Alia) integration",
    "Live audio/video rooms via LiveKit (Agora)",
    "Push notifications via Firebase FCM",
    "Dark/light theme with user customization",
    "MCP (Model Context Protocol) server for AI agent access",
    "Multi-language (i18n) support",
    "Monorepo with shared TypeScript types"
  ],
  "publicApiSurface": [
    "POST /auth/signup",
